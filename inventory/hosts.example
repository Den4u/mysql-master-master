[mysql]
# MySQL Master 1: host, user, port, and SSH key
master1 ansible_host=<master_ip1> ansible_user=<user1> ansible_ssh_port=22 ansible_ssh_private_key_file=/puth/to/key
# MySQL Master 2: host, user, port, and SSH key
master2 ansible_host=<master_ip2> ansible_user=<user2> ansible_ssh_port=22 ansible_ssh_private_key_file=/puth/to/key

[haproxy]
# HAProxy Load Balancer: host, user, port, and SSH key
haproxy_b ansible_host=haproxy_ip ansible_user=haproxy ansible_ssh_port=22 ansible_ssh_private_key_file=/puth/to/key
