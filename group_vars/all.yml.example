# Общие переменные

replica_user: replica

# --- mysqld.cnf ---
# Error log
log_error: /var/log/mysql/error.log

# Путь к bin-логам
log_bin: /var/log/mysql/mysql-bin.log
log_bin_index: /var/log/mysql/mysql-bin.index

# Relay лог для слейва
relay_log: /var/log/mysql/mysql-relay-bin
relay_log_index: /var/log/mysql/mysql-relay-bin.index

# Время хранения бин-логов
expire_logs_days: 7

# Максимальный размер бин-лога
max_binlog_size: 500M


# Fail2ban config - jail.local.j2:
logpath_ssh: "%(sshd_log)s"
maxretry_f2b: 2    
findtime_f2b: 5m
bantime_f2b: 1d
ignoreip_f2b: ip1 ip2
port_ssh_f2b: 22


#system UTC
timezone_: "Europe/Moscow"

# ufw
# --- ip_admin_host ---
admin_ssh_ip: ip_admin