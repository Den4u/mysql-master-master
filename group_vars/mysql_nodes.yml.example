# --- Mysqld.cnf ---
# mysql/templates/mysqld.cnf.j2

# Network interface to bind
bind_address: 0.0.0.0

# Error log file location
log_error: /var/log/mysql/error.log

# Path to binary logs
log_bin: /var/log/mysql/mysql-bin.log
log_bin_index: /var/log/mysql/mysql-bin.index

# Relay log for replication
relay_log: /var/log/mysql/mysql-relay-bin
relay_log_index: /var/log/mysql/mysql-relay-bin.index

# Retention period for binary logs
expire_logs_days: 7

# Maximum binary log file size
max_binlog_size: 500M


# --- Database user for replication ---
replica_user: replica


# --- User for Zabbix MySQL monitoring plugin ---
zbx_monitor_user: zbx_monitor_username

# MySQL host address
zbx_localhost: localhost
# MySQL service port
zbx_mysql_port: 3306


# --- HAProxy ---
# Private IP address of HAProxy node
haproxy_host_ip: haproxy_host_private_ip