# HAProxy configuration for MySQL Master-Master cluster

global
    log /dev/log local0
    log /dev/log local1 notice
    chroot /var/lib/haproxy
    user haproxy
    group haproxy
    daemon
    maxconn 2000

defaults
    log     global
    mode    tcp
    option  tcplog
    timeout connect 5s
    timeout client  1m
    timeout server  1m

frontend mysql_front
    bind *:3306
    mode tcp
    default_backend mysql_back

# Backend: Active-Passive failover configuration
# Primary master handles all traffic; standby master takes over on failure
backend mysql_back
    mode tcp
    option tcp-check

    balance first 

    # Active master
    server {{ master1_name }} {{ master1_ip }}:3306 check inter 2000 rise 2 fall 3
    # Standby master (activates only when active fails)
    server {{ master2_name }} {{ master2_ip }}:3306 check inter 2000 rise 2 fall 3 backup

# HAProxy statistics panel
listen stats
    bind {{ haproxy_stats_panel_bind }}:{{ haproxy_stats_panel_port }}
    mode http
    stats enable
    stats uri /{{ admin_panel }}
    stats refresh {{ web_stats_resfresh }}

    stats auth {{ login_haproxy }}:{{ passwd_haproxy }}
